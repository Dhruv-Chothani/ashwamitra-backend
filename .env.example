# ===== ASWAMITHRA BACKEND CONFIGURATION =====
# Copy this file to .env and fill in your values

# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/ashwamitra
# Or use MongoDB Atlas: mongodb+srv://<username>:<password>@cluster.mongodb.net/aswamithra

# Server
PORT=5000

# JWT Secret (change this to a random string)
JWT_SECRET=your_super_secret_jwt_key_change_this

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:8080,http://localhost:8081,http://localhost:8082,http://localhost:8083

# Razorpay Configuration
RAZORPAY_KEY_ID=rzp_test_your_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here
